            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('superAdminToken', response.data.accessToken);",
                  "    pm.test('Login successful', () => {",
