                }
              ]
            }
          }
        },
        {
          "name": "Revoke User Access",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Revoked\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/super-admin/users/:userId/status",
              "host": ["{{baseUrl}}"],
              "path": ["super-admin", "users", ":userId", "status"],
              "variable": [
                {
                  "key": "userId",
                  "value": "PASTE_USER_UUID_HERE"
                }
              ]
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/super-admin/users/:userId",
              "host": ["{{baseUrl}}"],
              "path": ["super-admin", "users", ":userId"],
              "variable": [
                {
                  "key": "userId",
                  "value": "PASTE_USER_UUID_HERE"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "School Admin",
      "item": [
        {
          "name": "Register Teacher",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Teacher Name\",\n  \"email\": \"teacher@example.com\",\n  \"role\": \"teacher\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/school-admin/register-user",
              "host": ["{{baseUrl}}"],
              "path": ["school-admin", "register-user"]
            }
          }
        },
        {
          "name": "Register Student",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Student Name\",\n  \"email\": \"student@example.com\",\n  \"role\": \"student\",\n  \"grade\": \"10\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/school-admin/register-user",
