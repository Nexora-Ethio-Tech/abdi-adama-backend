              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Auditor\",\n  \"email\": \"newauditor@example.com\",\n  \"branchId\": \"PASTE_BRANCH_UUID_HERE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/super-admin/create-auditor",
